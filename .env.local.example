# Copy to .env.local and fill in. NEVER commit .env.local — it's gitignored.
# All values below are intentionally blank; this file is a safe template.

# ── Supabase ────────────────────────────────────────────────────────────────
# Use the BARE project URL — do NOT include a /rest/v1 suffix.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role / secret key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Site / Pixel ────────────────────────────────────────────────────────────
# Public site origin, e.g. http://localhost:3000 in dev, your domain in prod.
NEXT_PUBLIC_SITE_URL=
# Meta Pixel id. Falls back to the hardcoded id in lib/metaPixel.ts if unset,
# but set it explicitly in production.
NEXT_PUBLIC_META_PIXEL_ID=983903721133077
# Microsoft Clarity project id (session replay / heatmaps). Falls back to the
# hardcoded id in components/Clarity.tsx if unset.
NEXT_PUBLIC_CLARITY_ID=xd8vzg0ua8

# ── Resend (transactional + OTP email) ──────────────────────────────────────
RESEND_API_KEY=
# Must be a VERIFIED Resend sender on a domain you own (not a gmail address).
EMAIL_FROM=

# ── Lead cookie signing ─────────────────────────────────────────────────────
# Any long random string. Signs the short-lived lead_id cookie. REQUIRED.
LEAD_COOKIE_SECRET=

# ── Supabase "Send Email" hook (optional — bypasses SMTP for OTP) ────────────
# If you enable Authentication → Hooks → Send Email Hook (HTTPS → /api/auth/send-email),
# paste the secret it shows here (looks like "v1,whsec_..."). OTP codes then send
# via Resend's API instead of Supabase SMTP.
SEND_EMAIL_HOOK_SECRET=

# ── Founder video (optional) ────────────────────────────────────────────────
# Self-hosted mp4 or an unlisted YouTube/Vimeo embed url; falls back gracefully.
NEXT_PUBLIC_FOUNDER_VIDEO_URL=

# ── Razorpay ────────────────────────────────────────────────────────────────
# TEST keys in dev, LIVE keys in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# The signing secret from your Razorpay webhook (→ /api/razorpay/webhook).
RAZORPAY_WEBHOOK_SECRET=
